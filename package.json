{
  "name": "pstock-telegram-bot",
  "version": "1.0.0",
  "description": "Telegram bot and web app for store inventory management",
  "main": "bot/index.js",
  "scripts": {
    "start": "node bot/index.js",
    "start:client-bot": "node client-bot/index.js",
    "start:server": "node server.js",
    "dev": "nodemon bot/index.js",
    "dev:client-bot": "nodemon client-bot/index.js",
    "dev:server": "nodemon server.js",
    "migrate": "node migrations/run.js",
    "db:ensure-address": "node scripts/ensureAddressTable.js",
    "seed:catalog": "node scripts/seedCatalogFromElements.js",
    "export:data": "node scripts/exportData.js",
    "create-admin": "node scripts/createAdmin.js",
    "test:bot": "node scripts/testBot.js",
    "test:db": "node scripts/testDb.js"
  },
  "keywords": ["telegram", "bot", "inventory", "store"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "node-telegram-bot-api": "^0.64.0",
    "pg": "^8.11.3",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "xlsx": "^0.18.5",
    "joi": "^17.11.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
